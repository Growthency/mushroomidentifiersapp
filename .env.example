# Copy this file to .env and fill in real values.
# See .env (gitignored) for detailed setup notes per service.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude (vision + chat)
EXPO_PUBLIC_ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY=
EXPO_PUBLIC_ANTHROPIC_MODEL_FREE=claude-haiku-4-5-20251001
EXPO_PUBLIC_ANTHROPIC_MODEL_PAID=claude-sonnet-4-6

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=

# iNaturalist (no key)
EXPO_PUBLIC_INATURALIST_API_BASE=https://api.inaturalist.org/v1

# OpenWeather
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# PostHog
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AdMob (free-tier ads, auto-disabled for premium users)
EXPO_PUBLIC_ADMOB_APP_ID_IOS=
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADS_USE_TEST_IDS=true
EXPO_PUBLIC_REWARDED_AD_CREDITS=10

# App
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# Website integration
EXPO_PUBLIC_WEBSITE_URL=https://mushroomidentifiers.com
EXPO_PUBLIC_WEBSITE_API_BASE=https://mushroomidentifiers.com/api
EXPO_PUBLIC_DEEP_LINK_DOMAIN=mushroomidentifiers.com

# Feature flags
EXPO_PUBLIC_ENABLE_AI_CHAT=true
EXPO_PUBLIC_ENABLE_AR_VIEW=false
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_COMMUNITY=true
EXPO_PUBLIC_ENABLE_RECIPES=true
EXPO_PUBLIC_ENABLE_VOICE_GUIDE=true
EXPO_PUBLIC_ENABLE_SPORE_PRINT_TOOL=true
EXPO_PUBLIC_ENABLE_LIVE_CAMERA_DETECTION=true
EXPO_PUBLIC_ENABLE_GAMIFICATION=true

# Credits / pricing
EXPO_PUBLIC_CREDITS_PER_IDENTIFICATION=10
EXPO_PUBLIC_FREE_LIFETIME_CREDITS=30
EXPO_PUBLIC_STARTER_MONTHLY_CREDITS=120
EXPO_PUBLIC_EXPLORER_MONTHLY_CREDITS=550
EXPO_PUBLIC_PRO_MONTHLY_CREDITS=1200
